# =============================================================================
# Root Environment Configuration
# On-Premise RAG-LLM System v2
# =============================================================================

# --- Host Paths ---
DOC_WATCH_DIR=/data/documents

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rag_system
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DATA_DIR=/data/db/postgres

# --- Neo4j ---
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATA_DIR=/data/db/neo4j

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_DATA_DIR=/data/db/redis

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- JWT ---
JWT_SECRET=CHANGE_THIS_SECRET_IN_PRODUCTION_MIN_32_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# --- Embedding Model (BGE-M3, 1024-dim) ---
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_MODEL_DIR=/data/models/embedding
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32

# --- Reranker Model ---
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_MODEL_DIR=/data/models/reranker
RERANKER_DEVICE=cuda

# --- vLLM ---
VLLM_BASE_URL=http://vllm-server:8000/v1
VLLM_MODEL_NAME=local-llm
# Hugging Face repo ID or local mounted model path, e.g. /models/vllm/Qwen2.5-72B-Instruct-AWQ
VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct-AWQ
VLLM_QUANTIZATION=awq
VLLM_TENSOR_PARALLEL=1
VLLM_GPU_MEM_UTIL=0.90
VLLM_MAX_MODEL_LEN=32768
VLLM_SERVED_MODEL_NAME=local-llm
VLLM_MODEL_DIR=/data/models/vllm
VLLM_GPU_COUNT=1
PREFER_ENV_LLM_CONFIG=true

# --- MinerU OCR ---
MINERU_API_URL=http://mineru-api:9000
MINERU_BACKEND=hybrid-auto-engine
MINERU_LANG=korean
MINERU_MODEL_DIR=/data/models/mineru
MINERU_OUTPUT_DIR=/data/images/mineru_output

# --- Chunking ---
CHUNK_STRATEGY=hybrid
CHUNK_SIZE=512
CHUNK_OVERLAP=50
CHUNK_MIN_SECTION_TOKENS=80

# --- Image ---
ENABLE_IMAGE_EMBEDDING=true
IMAGE_STORE_DIR=/data/images

# --- Web Search (Google Custom Search API) ---
WEB_SEARCH_ENABLED=true
GOOGLE_API_KEY=
GOOGLE_CX=

# --- HuggingFace ---
HF_TOKEN=

# --- Development / Smoke Validation ---
SMOKE_TEST_MODE=false

# --- Sync Schedule ---
SYNC_INTERVAL_MINUTES=30
SOURCE_SCAN_PATHS=/data/documents
PIPELINE_API_URL=http://pipeline-api:8001
DEFAULT_DEPT_ID=1
DEFAULT_ROLE_ID=3

# --- Frontend ---
# Leave empty to use the current browser host with port 8002.
# Example for remote access: http://192.168.0.10:8002
NEXT_PUBLIC_API_URL=
