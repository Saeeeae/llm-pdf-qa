FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1

ARG MINERU_PIP_SPEC="mineru[all]"
# CUDA wheel index — change if your host CUDA version differs
# cu118 / cu121 / cu124 etc.
ARG CUDA_INDEX="https://download.pytorch.org/whl/cu124"

# Kakao apt mirror + system deps + Python 3.10
RUN sed -i 's|http://archive.ubuntu.com/ubuntu|http://mirror.kakao.com/ubuntu|g' /etc/apt/sources.list \
    && sed -i 's|http://security.ubuntu.com/ubuntu|http://mirror.kakao.com/ubuntu|g' /etc/apt/sources.list \
    && apt-get update && apt-get install -y --no-install-recommends \
        python3.10 \
        python3.10-dev \
        python3-pip \
        libgl1-mesa-glx \
        libglib2.0-0 \
        libsm6 \
        libxext6 \
        libxrender1 \
        poppler-utils \
        tesseract-ocr \
        tesseract-ocr-kor \
        libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# python / python3 symlinks
RUN ln -sf /usr/bin/python3.10 /usr/bin/python3 \
    && ln -sf /usr/bin/python3.10 /usr/bin/python

# 1) Install CUDA-capable PyTorch FIRST so mineru[all] won't overwrite with CPU torch
RUN pip3 install --no-cache-dir torch torchvision torchaudio \
    --index-url "$CUDA_INDEX"

# 2) Install MinerU + API server
COPY mineru/requirements.txt ./requirements.txt
RUN pip3 install --no-cache-dir "$MINERU_PIP_SPEC" \
    && pip3 install --no-cache-dir -r requirements.txt \
    && rm -rf /root/.cache /tmp/*

COPY mineru/mineru_api.py ./mineru/mineru_api.py

EXPOSE 9000

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:9000/health', timeout=5)"

CMD ["python3", "-m", "uvicorn", "mineru.mineru_api:app", "--host", "0.0.0.0", "--port", "9000", "--workers", "1"]
