FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    DEBIAN_FRONTEND=noninteractive \
    TZ=Etc/UTC

RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ >/etc/timezone && \
    apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY rag-pipeline/requirements.local.txt .
RUN python -m pip install --upgrade pip && \
    python -m pip install --no-cache-dir -r requirements.local.txt

COPY shared /app/shared
COPY rag-pipeline /app/rag_pipeline

ENV PYTHONPATH=/app
CMD ["python", "-m", "uvicorn", "rag_pipeline.api.main:app", "--host", "0.0.0.0", "--port", "8001"]
